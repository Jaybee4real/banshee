#!/bin/bash
# Runs as root after the app lands in /Applications. Starts the per-user
# background agent in the console user's GUI session so no Terminal step is needed.

CONSOLE_USER=$(/usr/bin/stat -f%Su /dev/console)
if [ -z "$CONSOLE_USER" ] || [ "$CONSOLE_USER" = "root" ]; then
  exit 0
fi
CONSOLE_UID=$(/usr/bin/id -u "$CONSOLE_USER")

/bin/launchctl asuser "$CONSOLE_UID" /usr/bin/sudo -u "$CONSOLE_USER" \
  /Applications/Banshell.app/Contents/MacOS/banshell install || true

exit 0
